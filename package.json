{
  "name": "prompts",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.10.0",
  "scripts": {
    "build": "pnpm run web:clean && pnpm run web:build && pnpm run web:index && pnpm run web:check",
    "lint": "eslint web eslint.config.js playwright.config.mjs",
    "format:check": "prettier --check package.json pnpm-workspace.yaml pagefind.yml vercel.json eslint.config.js playwright.config.mjs \"web/**/*.{css,html,js,mjs}\"",
    "web:clean": "node web/clean.mjs",
    "web:build": "node web/build.mjs",
    "web:index": "pagefind",
    "web:check": "node web/check.mjs",
    "web:test": "node --test \"web/test/*.test.mjs\"",
    "web:test:browser": "playwright test",
    "web:serve": "pnpm run build && pagefind --serve"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "eslint": "10.6.0",
    "github-markdown-css": "5.9.0",
    "github-slugger": "2.0.0",
    "globals": "17.7.0",
    "highlight.js": "11.11.1",
    "js-yaml": "5.2.1",
    "markdown-it": "14.3.0",
    "markdown-it-footnote": "4.0.0",
    "markdown-it-task-lists": "2.1.1",
    "markdown-link-check": "3.14.2",
    "markdownlint-cli2": "0.22.1",
    "pagefind": "1.5.2",
    "prettier": "3.9.4",
    "sanitize-html": "2.17.5"
  }
}
